# Market data provider. Keep `mock` if the Akshare bridge is not running.
DATA_PROVIDER=mock
AKSHARE_API_URL=http://127.0.0.1:8000
AKSHARE_API_KEY=
AKSHARE_REQUEST_TIMEOUT_MS=8000
AKSHARE_HEALTH_TIMEOUT_MS=3000
AKSHARE_CACHE_TTL_SECONDS=900
AKSHARE_MAX_SYMBOLS=30
AKSHARE_SNAPSHOT_TIMEOUT_SECONDS=75
TUSHARE_API_URL=
TUSHARE_TOKEN=

# Research AI provider. Use `deepseek` only when DEEPSEEK_API_KEY is configured.
RESEARCH_AI_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
